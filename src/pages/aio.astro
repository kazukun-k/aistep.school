  <script is:inline>
    // -------------------------------------------------------------
    // 金額計算・フォーマット関数
    // -------------------------------------------------------------
    const formatYen = (num) => {
        if (num >= 100000000) {
            const oku = Math.floor(num / 100000000);
            const man = Math.floor((num % 100000000) / 10000);
            return `${oku}億${man > 0 ? man + '万' : ''}円`;
        }
        return `${(num / 10000).toLocaleString()}万円`;
    };

    const calcPlan1 = (rev) => rev * 0.01; // 1%
    const calcPlan2 = (rev) => rev * 0.03; // 3%
    const calcPlan3Monthly = (rev) => {
        const calculated = (rev * 0.001) / 12;
        return Math.max(calculated, 5000); // 最低月額5,000円
    };
    const calcPlan4Monthly = (rev) => {
        const calculated = (rev * 0.002) / 12;
        return Math.max(calculated, 10000); // 最低月額10,000円
    };
    const calcPlan5Monthly = (rev) => {
        const calculated = (rev * 0.003) / 12;
        return Math.max(calculated, 15000); // 最低月額15,000円
    };

    // -------------------------------------------------------------
    // DOM要素の参照
    // -------------------------------------------------------------
    const simSlider = document.getElementById('sim-revenue-slider');
    const simText = document.getElementById('sim-revenue-text');

    // -------------------------------------------------------------
    // 年商変更処理
    // -------------------------------------------------------------
    function updateRevenue(val) {
        const revenue = Number(val);
        
        // 想定年商テキスト同期
        if (simText) simText.innerText = formatYen(revenue);

        // 金額計算＆表示更新
        const p1 = calcPlan1(revenue);
        const p2 = calcPlan2(revenue);
        const p3 = calcPlan3Monthly(revenue);
        const p4 = calcPlan4Monthly(revenue);
        const p5 = calcPlan5Monthly(revenue);

        const p1Formatted = formatYen(p1);
        const p2Formatted = formatYen(p2);
        const p3Formatted = formatYen(p3) + ' / 月';
        const p4Formatted = formatYen(p4) + ' / 月';
        const p5Formatted = formatYen(p5) + ' / 月';

        document.querySelectorAll('.plan1-price-display').forEach(el => el.innerText = p1Formatted);
        document.querySelectorAll('.plan2-price-display').forEach(el => el.innerText = p2Formatted);
        document.querySelectorAll('.plan3-price-display').forEach(el => el.innerText = p3Formatted);
        document.querySelectorAll('.plan4-price-display').forEach(el => el.innerText = p4Formatted);
        document.querySelectorAll('.plan5-price-display').forEach(el => el.innerText = p5Formatted);
    }

    // スライダーのイベント紐付け
    if (simSlider) {
        simSlider.addEventListener('input', (e) => updateRevenue(e.target.value));
    }

    // 初期化実行
    updateRevenue(30000000);
  </script>
