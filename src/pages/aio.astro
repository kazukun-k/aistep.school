  <script is:inline>
    // -------------------------------------------------------------
    // 金額計算・フォーマット関数
    // -------------------------------------------------------------
    const formatYen = (num) => {
        if (num >= 100000000) {
            const oku = Math.floor(num / 100000000);
            const man = Math.floor((num % 100000000) / 10000);
            return `${oku}億${man > 0 ? man + '万' : ''}円`;
        }
        return `${(num / 10000).toLocaleString()}万円`;
    };

    const calcPlan1 = (rev) => rev * 0.01; // 1%
    const calcPlan2 = (rev) => rev * 0.03; // 3%
    const calcPlan3Monthly = (rev) => {
        const calculated = (rev * 0.001) / 12;
        return Math.max(calculated, 5000); // 最低月額5,000円
    };
    const calcPlan4Monthly = (rev) => {
        const calculated = (rev * 0.002) / 12;
        return Math.max(calculated, 10000); // 最低月額10,000円
    };
    const calcPlan5Monthly = (rev) => {
        const calculated = (rev * 0.003) / 12;
        return Math.max(calculated, 15000); // 最低月額15,000円
    };

    // -------------------------------------------------------------
    // DOM要素の参照
    // -------------------------------------------------------------
    const simSlider = document.getElementById('sim-revenue-slider');
    const simText = document.getElementById('sim-revenue-text');

    // -------------------------------------------------------------
    // 年商変更処理
    // -------------------------------------------------------------
    function updateRevenue(val) {
        const revenue = Number(val);
        
        // 想定年商テキスト同期
        if (simText) simText.innerText = formatYen(revenue);

        // 金額計算＆表示更新
        const p1 = calcPlan1(revenue);
        const p2 = calcPlan2(revenue);
        const p3 = calcPlan3Monthly(revenue);
        const p4 = calcPlan4Monthly(revenue);
        const p5 = calcPlan5Monthly(revenue);

        const p1Formatted = formatYen(p1);
        const p2Formatted = formatYen(p2);
        const p3Formatted = formatYen(p3) + ' / 月';
        const p4Formatted = formatYen(p4) + ' / 月';
        const p5Formatted = formatYen(p5) + ' / 月';

        document.querySelectorAll('.plan1-price-display').forEach(el => el.innerText = p1Formatted);
        document.querySelectorAll('.plan2-price-display').forEach(el => el.innerText = p2Formatted);
        document.querySelectorAll('.plan3-price-display').forEach(el => el.innerText = p3Formatted);
        document.querySelectorAll('.plan4-price-display').forEach(el => el.innerText = p4Formatted);
        document.querySelectorAll('.plan5-price-display').forEach(el => el.innerText = p5Formatted);
    }

    // スライダーのイベント紐付け
    if (simSlider) {
        simSlider.addEventListener('input', (e) => updateRevenue(e.target.value));
    }

    // 初期化実行
    updateRevenue(30000000);

    // -------------------------------------------------------------
    // お申し込みフォーム送信処理 (FormSubmit.co API経由)
    // -------------------------------------------------------------
    const form = document.getElementById('diagnostic-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnSpinner = document.getElementById('btn-spinner');
    const formMessage = document.getElementById('form-message');

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // ボタンを送信中に設定
            submitBtn.disabled = true;
            btnText.innerText = '送信中...';
            btnSpinner.classList.remove('hidden');
            formMessage.classList.add('hidden');
            formMessage.className = 'hidden text-xs font-bold p-4 rounded-xl leading-relaxed'; // クラス初期化

            const companyName = document.getElementById('company_name').value;
            const email = document.getElementById('email').value;
            const websiteUrl = document.getElementById('website_url').value;

            // 自動返信メールの本文を作成
            const autoresponseMessage = `${companyName} 様

この度は、生成AIStepSchoolの「無料AIおすすめ度診断」にお申し込みいただき、誠にありがとうございます。

本メールは、お申し込みを正常に受け付けたことをお知らせする自動配信メールです。

ご入力いただいた以下の内容に基づき、現在AI検索エンジン（ChatGPTやGemini等）において貴店がどのように推薦・評価されているかを詳細に分析いたします。

--------------------------------------------------
【お申し込み内容の控え】
■ 店舗名 / 会社名： ${companyName}
■ メールアドレス： ${email}
■ ホームページURL： ${websiteUrl}
--------------------------------------------------

診断レポートの作成には現在2〜3営業日ほどお時間をいただいております。
診断が完了いたしましたら、改めて担当者より診断レポートを添付の上、ご連絡させていただきます。今しばらくお待ちいただけますと幸いです。

※本メールは自動送信となっております。万が一、3営業日以上経過しても返信が届かない場合や、お申し込み内容に誤りがあった場合は、大変お手数ですが aistep.school@gmail.com まで直接ご連絡ください。

--------------------------------------------------
生成AIStepSchool 事務局
メールアドレス： aistep.school@gmail.com
--------------------------------------------------`;

            const payload = {
                "店舗名 / 会社名": companyName,
                "email": email,
                "現在のホームページURL": websiteUrl,
                "_subject": `【無料AIおすすめ度診断】新規お申し込み - ${companyName}`,
                "_autoresponse": autoresponseMessage
            };

            try {
                const response = await fetch('https://formsubmit.co/ajax/7687515851ebdcaa85f78df88c3268cf', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (response.ok && data.success === "true") {
                    formMessage.classList.remove('hidden');
                    formMessage.classList.add('bg-emerald-50', 'text-emerald-700', 'border', 'border-emerald-200');
                    formMessage.innerText = '✨ お申し込みありがとうございます！診断レポート用メールの送信を完了しました。ご入力いただいたアドレス宛に確認メールを送信しております。';
                    form.reset();
                } else {
                    throw new Error('送信エラーが発生しました。');
                }
            } catch (error) {
                console.error(error);
                formMessage.classList.remove('hidden');
                formMessage.classList.add('bg-red-50', 'text-red-600', 'border', 'border-red-200');
                formMessage.innerText = '❌ 送信に失敗しました。時間をおいて再度お試しいただくか、直接 aistep.school@gmail.com までご連絡ください。';
            } finally {
                submitBtn.disabled = false;
                btnText.innerText = '無料診断レポートを申し込む';
                btnSpinner.classList.add('hidden');
            }
        });
