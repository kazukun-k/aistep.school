  <script is:inline>
    // -------------------------------------------------------------
    // スライドデータ定義
    // -------------------------------------------------------------
    const slideTitles = [
        "", // 表紙
        "今、スマホの「探し方」が激変しています",
        "AIはあなたのお店を「どこ」で判断しているか？",
        "ポータルサイトと自社ホームページの決定的な違い",
        "成果に連動する、新しい店舗支援料金プラン",
        "【既存HPあり】ホームページ最適化・AIO納品パック",
        "【新規制作】AI特化型HP完全構築パック",
        "【月額運用】ホームページ修正・保守・MEO管理",
        "【教育】店舗のための「生成AI活用・自走コンサル」",
        "店舗様の「年商」をベースとした料金シミュレーター"
    ];

    let currentSlide = 0;
    const totalSlides = 10;
    let revenue = 30000000; // 初期値：年商3000万円

    // -------------------------------------------------------------
    // 金額計算・フォーマット関数
    // -------------------------------------------------------------
    const formatYen = (num) => {
        if (num >= 100000000) {
            const oku = Math.floor(num / 100000000);
            const man = Math.floor((num % 100000000) / 10000);
            return `${oku}億${man > 0 ? man + '万' : ''}円`;
        }
        return `${(num / 10000).toLocaleString()}万円`;
    };

    const calcPlan1 = (rev) => rev * 0.01; // 1%
    const calcPlan2 = (rev) => rev * 0.03; // 3%
    const calcPlan3Monthly = (rev) => {
        const calculated = (rev * 0.001) / 12;
        return Math.max(calculated, 5000); // 最低月額5,000円
    };

    // -------------------------------------------------------------
    // DOM要素の参照
    // -------------------------------------------------------------
    const container = document.getElementById('slide-container');
    const slideHeaderBar = document.getElementById('slide-header-bar');
    const slideFooterBar = document.getElementById('slide-footer-bar');
    const slideTitleText = document.getElementById('slide-title-text');
    const slideNumberBadge = document.getElementById('slide-number-badge');
    const slideProgressText = document.getElementById('slide-progress-text');
    const pageNumDisplay = document.getElementById('page-num-display');
    const prevSlideBtn = document.getElementById('prev-slide-btn');
    const nextSlideBtn = document.getElementById('next-slide-btn');
    const dotsContainer = document.getElementById('dot-indicators-container');
    const mobileSettingsBtn = document.getElementById('mobile-settings-btn');
    const mobileSettingsPanel = document.getElementById('mobile-settings-panel');

    // スライダーと想定年商テキストの参照
    const desktopSlider = document.getElementById('desktop-revenue-slider');
    const desktopText = document.getElementById('desktop-revenue-text');
    const mobileSlider = document.getElementById('mobile-revenue-slider');
    const mobileText = document.getElementById('mobile-revenue-text');
    const mobileCompactText = document.getElementById('mobile-compact-revenue-text');
    const simSlider = document.getElementById('sim-revenue-slider');
    const simText = document.getElementById('sim-revenue-text');

    // -------------------------------------------------------------
    // 年商変更処理
    // -------------------------------------------------------------
    function updateRevenue(val) {
        revenue = Number(val);
        
        // スライダー値同期
        if (desktopSlider) desktopSlider.value = revenue;
        if (mobileSlider) mobileSlider.value = revenue;
        if (simSlider) simSlider.value = revenue;

        // 想定年商テキスト同期
        const formatted = formatYen(revenue);
        if (desktopText) desktopText.innerText = formatted;
        if (mobileText) mobileText.innerText = formatted;
        if (mobileCompactText) mobileCompactText.innerText = formatted;
        if (simText) simText.innerText = formatted;

        // 金額計算＆表示更新
        const p1 = calcPlan1(revenue);
        const p2 = calcPlan2(revenue);
        const p3 = calcPlan3Monthly(revenue);

        const p1Formatted = formatYen(p1);
        const p2Formatted = formatYen(p2);
        const p3Formatted = formatYen(p3) + ' / 月';

        document.querySelectorAll('.plan1-price-display').forEach(el => el.innerText = p1Formatted);
        document.querySelectorAll('.plan2-price-display').forEach(el => el.innerText = p2Formatted);
        document.querySelectorAll('.plan3-price-display').forEach(el => el.innerText = p3Formatted);
    }

    // 各スライダーのイベント紐付け
    if (desktopSlider) desktopSlider.addEventListener('input', (e) => updateRevenue(e.target.value));
    if (mobileSlider) mobileSlider.addEventListener('input', (e) => updateRevenue(e.target.value));
    if (simSlider) simSlider.addEventListener('input', (e) => updateRevenue(e.target.value));

    // -------------------------------------------------------------
    // スライド切り替えロジック
    // -------------------------------------------------------------
    function showSlide(index) {
        if (index < 0 || index >= totalSlides) return;
        currentSlide = index;

        // 全スライドを非表示にし、対象のスライドのみ表示
        for (let i = 0; i < totalSlides; i++) {
            const slide = document.getElementById(`slide-${i}`);
            if (slide) {
                if (i === currentSlide) {
                    slide.classList.remove('hidden');
                } else {
                    slide.classList.add('hidden');
                }
            }
        }

        // 常駐ヘッダーとスライド内フッターの表示制御（表紙以外で表示）
        if (currentSlide === 0) {
            if (slideHeaderBar) slideHeaderBar.classList.add('hidden');
            if (slideFooterBar) slideFooterBar.classList.add('hidden');
        } else {
            if (slideHeaderBar) {
                slideHeaderBar.classList.remove('hidden');
                slideTitleText.innerText = slideTitles[currentSlide];
                slideNumberBadge.innerText = currentSlide; // 表紙が0なので、スライド1は「1」に
                slideProgressText.innerText = `Page ${currentSlide + 1} of ${totalSlides}`;
            }
            if (slideFooterBar) slideFooterBar.classList.remove('hidden');
        }

        // ドットの同期
        for (let i = 0; i < totalSlides; i++) {
            const dot = document.getElementById(`dot-${i}`);
            if (dot) {
                if (i === currentSlide) {
                    dot.className = "w-3 h-3 rounded-full transition-all cursor-pointer bg-emerald-400 scale-125";
                } else {
                    dot.className = "w-3 h-3 rounded-full transition-all cursor-pointer bg-slate-800 hover:bg-slate-600";
                }
            }
        }

        // ページ番号テキストの更新
        if (pageNumDisplay) {
            pageNumDisplay.innerText = `${String(currentSlide + 1).padStart(2, '0')} / ${String(totalSlides).padStart(2, '0')}`;
        }

        // ボタンの無効化
        if (prevSlideBtn) {
            if (currentSlide === 0) {
                prevSlideBtn.classList.add('opacity-20', 'cursor-not-allowed');
                prevSlideBtn.disabled = true;
            } else {
                prevSlideBtn.classList.remove('opacity-20', 'cursor-not-allowed');
                prevSlideBtn.disabled = false;
            }
        }
        if (nextSlideBtn) {
            if (currentSlide === totalSlides - 1) {
                nextSlideBtn.classList.add('opacity-20', 'cursor-not-allowed');
                nextSlideBtn.disabled = true;
            } else {
                nextSlideBtn.classList.remove('opacity-20', 'cursor-not-allowed');
                nextSlideBtn.disabled = false;
            }
        }
    }

    // -------------------------------------------------------------
    // ドットインジケーターの生成
    // -------------------------------------------------------------
    function createDots() {
        if (!dotsContainer) return;
        dotsContainer.innerHTML = '';
        for (let i = 0; i < totalSlides; i++) {
            const btn = document.createElement('button');
            btn.id = `dot-${i}`;
            btn.className = `w-3 h-3 rounded-full transition-all cursor-pointer ${i === 0 ? 'bg-emerald-400 scale-125' : 'bg-slate-800'}`;
            btn.title = `スライド ${i + 1}`;
            btn.addEventListener('click', () => showSlide(i));
            dotsContainer.appendChild(btn);
        }
    }

    // ボタンのクリックイベント
    if (prevSlideBtn) prevSlideBtn.addEventListener('click', () => {
        if (currentSlide > 0) showSlide(currentSlide - 1);
    });
    if (nextSlideBtn) nextSlideBtn.addEventListener('click', () => {
        if (currentSlide < totalSlides - 1) showSlide(currentSlide + 1);
    });

    // キーボード操作
    window.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === ' ') {
            if (currentSlide < totalSlides - 1) showSlide(currentSlide + 1);
        } else if (e.key === 'ArrowLeft') {
            if (currentSlide > 0) showSlide(currentSlide - 1);
        }
    });

    // -------------------------------------------------------------
    // スケーリング（レスポンシブ）
    // -------------------------------------------------------------
    const baseWidth = 1024;
    const baseHeight = 576;

    function handleResize() {
        if (!container) return;
        const parent = container.parentElement;
        if (!parent) return;

        const parentWidth = parent.clientWidth;
        const parentHeight = parent.clientHeight;

        const scaleX = parentWidth / baseWidth;
        const scaleY = parentHeight / baseHeight;

        const newScale = Math.min(scaleX, scaleY);
        const scale = Math.max(0.3, Math.min(newScale * 0.95, 1.2));

        container.style.transform = `scale(${scale})`;
        container.style.transformOrigin = 'center center';
    }

    window.addEventListener('resize', handleResize);

    // モバイルトグル設定パネル
    if (mobileSettingsBtn && mobileSettingsPanel) {
        mobileSettingsBtn.addEventListener('click', () => {
            mobileSettingsPanel.classList.toggle('hidden');
        });
    }

    // 初期起動処理
    createDots();
    updateRevenue(30000000);
    showSlide(0);
    handleResize();
    setTimeout(handleResize, 150);
  </script>
</body>
</html>
