---
import { getCollection } from 'astro:content';

// 公開されているすべてのプロンプトを取得
const prompts = await getCollection('prompts', ({ data }) => {
  return data.isPublished;
});

// 日付の降順（最新順）にソート
const sortedPrompts = prompts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

// カテゴリリスト
const categories = ["すべて", "メール作成", "文章要約", "アイデア出し", "データ整理"];
const baseUrl = import.meta.env.BASE_URL;

// canonical URL の生成
const canonicalURL = new URL(`${baseUrl}prompts`, Astro.site || 'https://example.com').toString();
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>実践プロンプト集 - 生成AIStepSchool</title>
  <meta name="description" content="コピペするだけで実際のビジネス実務や日常で即使える、プロンプトマスター仕様の超詳細なAIプロンプト集です。目的別での絞り込みが可能です。">
  <link rel="canonical" href={canonicalURL} />
  <!-- OGP Tags -->
  <meta property="og:title" content="実践プロンプト集 - 生成AIStepSchool" />
  <meta property="og:description" content="コピペするだけで実際のビジネス実務や日常で即使える、プロンプトマスター仕様の超詳細なAIプロンプト集です。" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(`${baseUrl}images/instructor_avatar.png`, Astro.site || 'https://example.com').toString()} />
  <meta property="og:site_name" content="生成AIStepSchool" />
  <meta name="twitter:card" content="summary_large_image" />
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col font-sans">
  <header class="border-b border-slate-200 bg-white/95 backdrop-blur sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-row justify-between items-center gap-4">
      <a href={baseUrl} class="text-lg sm:text-xl font-black bg-gradient-to-r from-indigo-600 via-purple-600 to-cyan-600 bg-clip-text text-transparent tracking-tight shrink-0">
        生成AIStepSchool
      </a>
      <nav class="flex gap-2 sm:gap-4 text-xs sm:text-sm font-semibold items-center overflow-x-auto no-scrollbar py-1">
        <a href={baseUrl} class="hover:text-indigo-600 text-slate-600 transition-colors shrink-0">Home</a>
        <a href={`${baseUrl}articles`} class="hover:text-indigo-600 text-slate-600 transition-colors shrink-0">Articles</a>
        <a href={`${baseUrl}prompts`} class="text-indigo-600 font-semibold shrink-0">Prompts</a>
        <a href={`${baseUrl}course`} class="px-3 py-1.5 sm:px-4 sm:py-1.5 rounded-full bg-gradient-to-r from-indigo-600 to-cyan-600 text-white font-semibold text-[10px] sm:text-xs shadow-md shadow-indigo-600/10 hover:opacity-90 transition-opacity shrink-0 font-sans">AI School</a>
        <a href={`${baseUrl}aio`} class="px-3 py-1.5 sm:px-4 sm:py-1.5 rounded-full bg-gradient-to-r from-emerald-600 to-teal-500 text-white font-semibold text-[10px] sm:text-xs shadow-md shadow-emerald-600/10 hover:opacity-90 transition-opacity shrink-0 font-sans">集客に悩む店舗様へ</a>
      </nav>
    </div>
  </header>

  <main class="flex-grow max-w-6xl w-full mx-auto px-4 py-12">
    <!-- ページ見出し -->
    <div class="mb-10 text-center max-w-3xl mx-auto">
      <span class="px-3.5 py-1 text-xs font-bold rounded-full bg-indigo-50 text-indigo-600 border border-indigo-100/80 tracking-wider uppercase mb-4 inline-block">
        コピーして今すぐ使える
      </span>
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4 bg-gradient-to-r from-slate-900 via-indigo-950 to-slate-900 bg-clip-text">
        実践プロンプト集
      </h1>
      <p class="text-slate-500 text-sm md:text-base leading-relaxed font-normal">
        ビジネスの実務や日常作業の効率を劇的に高める、プロ仕様の超詳細AIプロンプトテンプレートです。<br />
        目的のカテゴリを選択し、コピーしてAI（Gemini, ChatGPTなど）に貼り付けてご活用ください。
      </p>
    </div>

    <!-- 絞り込みカテゴリボタン -->
    <div class="flex flex-wrap gap-2.5 justify-center mb-12">
      {categories.map((cat, index) => (
        <button 
          data-filter-btn={cat}
          class={`px-5 py-2.5 rounded-full text-xs sm:text-sm font-bold border transition-all cursor-pointer ${
            index === 0 
            ? "bg-gradient-to-r from-indigo-600 to-cyan-600 text-white border-transparent shadow-md shadow-indigo-600/10" 
            : "bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50 shadow-sm"
          }`}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- プロンプトリストグリッド -->
    {sortedPrompts.length === 0 ? (
      <div class="text-center py-20 border border-dashed border-slate-200 rounded-3xl bg-white shadow-sm max-w-2xl mx-auto">
        <p class="text-slate-500">現在、公開されているプロンプトはありません。</p>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8" id="prompts-container">
        {sortedPrompts.map(prompt => (
          <article 
            data-category={prompt.data.category}
            data-prompt-card
            class="bg-white border border-slate-200 rounded-3xl p-6 hover:border-indigo-300 hover:shadow-lg transition-all duration-300 transform flex flex-col group shadow-sm relative overflow-hidden"
          >
            <!-- 装飾用のバックグラウンドグロー効果（ホバー時に少し見える） -->
            <div class="absolute -right-16 -top-16 w-32 h-32 bg-indigo-500/5 rounded-full filter blur-xl group-hover:bg-indigo-500/10 transition-colors"></div>

            <div class="flex items-center justify-between gap-3 mb-4 relative z-10">
              <!-- カテゴリバッジ -->
              <span class="px-2.5 py-0.5 text-[10px] font-bold rounded-full bg-indigo-50 text-indigo-600 border border-indigo-100">
                {prompt.data.category}
              </span>
              <!-- 難易度バッジ -->
              <span class={`px-2.5 py-0.5 text-[10px] font-bold rounded-full border ${
                prompt.data.difficulty === '初級' 
                ? 'bg-emerald-50 text-emerald-600 border-emerald-100'
                : prompt.data.difficulty === '中級'
                ? 'bg-amber-50 text-amber-600 border-amber-100'
                : 'bg-rose-50 text-rose-600 border-rose-100'
              }`}>
                {prompt.data.difficulty}
              </span>
            </div>

            <!-- カテゴリ別アイコン -->
            <div class="mb-5 text-indigo-600 bg-indigo-50/50 p-3 rounded-2xl w-fit relative z-10 border border-indigo-100/50">
              {prompt.data.category === "メール作成" && (
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              )}
              {prompt.data.category === "文章要約" && (
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" x2="8" y1="13" y2="13"></line><line x1="16" x2="8" y1="17" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              )}
              {prompt.data.category === "アイデア出し" && (
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path><line x1="9" x2="15" y1="18" y2="18"></line><line x1="10" x2="14" y1="22" y2="22"></line></svg>
              )}
              {prompt.data.category === "データ整理" && (
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M12 22c5.523 0 10-2.239 10-5s-4.477-5-10-5S2 14.239 2 17s4.477 5 10 5z"></path><path d="M21.75 12c0-2.761-4.38-5-9.75-5s-9.75 2.239-9.75 5"></path><path d="M21.75 7c0-2.761-4.38-5-9.75-5S2.25 4.239 2.25 7"></path></svg>
              )}
            </div>

            <div class="flex-grow relative z-10">
              <h2 class="text-lg font-bold mb-2 line-clamp-2 text-slate-900 group-hover:text-indigo-600 transition-colors">
                <a href={`${baseUrl}prompts/${prompt.slug}`}>
                  {prompt.data.title}
                </a>
              </h2>
              <p class="text-slate-600 text-xs sm:text-sm line-clamp-3 mb-5 font-normal leading-relaxed">
                {prompt.data.description}
              </p>
            </div>

            <div class="border-t border-slate-100 pt-4 mt-auto flex items-center justify-between relative z-10">
              <span class="text-[11px] text-slate-400">
                推奨: <strong class="text-slate-600 font-semibold">{prompt.data.recommendedAI}</strong>
              </span>
              <a href={`${baseUrl}prompts/${prompt.slug}`} class="text-indigo-600 hover:text-indigo-500 text-xs font-bold inline-flex items-center gap-1">
                詳細・コピーする <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    )}
  </main>

  <!-- フッター -->
  <footer class="border-t border-slate-200 bg-white py-12 text-center text-slate-500 text-sm mt-20 shadow-inner">
    <div class="max-w-6xl mx-auto px-4">
      <p>&copy; {new Date().getFullYear()} 生成AIStepSchool. Built with Astro & Tailwind CSS.</p>
    </div>
  </footer>

  <!-- リアルタイム絞り込みスクリプト -->
  <script>
    const buttons = document.querySelectorAll('[data-filter-btn]');
    const cards = document.querySelectorAll('[data-prompt-card]');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter-btn');

        // ボタンのスタイル切り替え
        buttons.forEach(btn => {
          btn.classList.remove('bg-gradient-to-r', 'from-indigo-600', 'to-cyan-600', 'text-white', 'border-transparent', 'shadow-md', 'shadow-indigo-600/10');
          btn.classList.add('bg-white', 'text-slate-600', 'border-slate-200', 'shadow-sm');
        });
        button.classList.add('bg-gradient-to-r', 'from-indigo-600', 'to-cyan-600', 'text-white', 'border-transparent', 'shadow-md', 'shadow-indigo-600/10');
        button.classList.remove('bg-white', 'text-slate-600', 'border-slate-200', 'shadow-sm');

        // プロンプトカードのフェードアウト・イン処理
        cards.forEach(card => {
          const category = card.getAttribute('data-category');

          if (filter === 'すべて' || category === filter) {
            card.classList.remove('hidden');
            setTimeout(() => {
              card.classList.remove('opacity-0', 'scale-95');
            }, 10);
          } else {
            card.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
              card.classList.add('hidden');
            }, 300);
          }
        });
      });
    });
  </script>
</body>
</html>
