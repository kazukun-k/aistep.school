---
const baseUrl = import.meta.env.BASE_URL;

// URL パラメータから申し込まれたプランを取得 (例: ?plan=individual)
const plan = Astro.url.searchParams.get('plan') || '';

// 外部予約カレンダーリンク（Google予約スケジュールやTimeRexなどのURLを環境変数から取得可能）
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || 'https://calendar.google.com/calendar/appointments/schedules-mock-url';

// 計画された各コースの表示名
let planName = 'お申し込みプラン';
if (plan === 'beginner') planName = '初心者コース（初めての生成AI）';
if (plan === 'tuesday') planName = '火曜日コース';
if (plan === 'individual') planName = '個別コース（マンツーマン相談）';

// canonical URL の生成
const canonicalURL = new URL(`${baseUrl}course/thanks`, Astro.site || 'https://example.com').toString();
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>お申し込み完了 | 生成AI実践オンライン教室 - 生成AIStepSchool</title>
  <meta name="description" content="生成AI実践オンライン教室へのお申し込みが完了しました。">
  <link rel="canonical" href={canonicalURL} />
  <!-- OGP Tags -->
  <meta property="og:title" content="お申し込み完了 | 生成AI実践オンライン教室 - 生成AIStepSchool" />
  <meta property="og:description" content="生成AI実践オンライン教室へのお申し込みが完了しました。" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(`${baseUrl}images/instructor_avatar.png`, Astro.site || 'https://example.com').toString()} />
  <meta property="og:site_name" content="生成AIStepSchool" />
  <meta name="twitter:card" content="summary_large_image" />
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col font-sans">
  <header class="border-b border-slate-200 bg-white/95 backdrop-blur sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-row justify-between items-center gap-4">
      <a href={baseUrl} class="text-lg sm:text-xl font-black bg-gradient-to-r from-indigo-600 via-purple-600 to-cyan-600 bg-clip-text text-transparent tracking-tight shrink-0">
        生成AIStepSchool
      </a>
      <nav class="flex gap-2 sm:gap-4 text-xs sm:text-sm font-semibold items-center overflow-x-auto no-scrollbar py-1">
        <a href={baseUrl} class="hover:text-indigo-600 text-slate-600 transition-colors shrink-0">Home</a>
        <a href={`${baseUrl}articles`} class="hover:text-indigo-600 text-slate-600 transition-colors shrink-0">Articles</a>
        <a href={`${baseUrl}course`} class="px-3 py-1.5 sm:px-4 sm:py-1.5 rounded-full bg-gradient-to-r from-indigo-600 to-cyan-600 text-white font-semibold text-[10px] sm:text-xs shadow-md shadow-indigo-600/10 hover:opacity-90 transition-opacity shrink-0 font-sans">AI School</a>
        <a href={`${baseUrl}aio`} class="px-3 py-1.5 sm:px-4 sm:py-1.5 rounded-full bg-gradient-to-r from-emerald-600 to-teal-500 text-white font-semibold text-[10px] sm:text-xs shadow-md shadow-emerald-600/10 hover:opacity-90 transition-opacity shrink-0 font-sans">AI店舗集客</a>
      </nav>
    </div>
  </header>

  <main class="flex-grow flex items-center justify-center py-16 px-4 relative">
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-indigo-100/20 rounded-full filter blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-cyan-100/20 rounded-full filter blur-3xl"></div>

    <div class="max-w-xl w-full text-center relative z-10 bg-white border border-slate-200 p-8 md:p-12 rounded-3xl shadow-sm">
      <!-- チェックマークのアニメーション演出 -->
      <div class="w-20 h-20 bg-gradient-to-r from-indigo-600 to-cyan-600 rounded-full flex items-center justify-center mx-auto mb-8 shadow-lg shadow-indigo-600/20 relative animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <span class="text-cyan-600 text-xs font-bold tracking-widest uppercase block mb-3">Thank you!</span>
      <h1 class="text-3xl font-black text-slate-900 mb-2">お申し込みありがとうございます</h1>
      <p class="text-slate-655 text-sm mb-6">{planName}の決済手続きが正常に完了しました。</p>

      <!-- コースごとの案内案内 -->
      <div class="bg-slate-50 border border-slate-200/80 p-6 rounded-2xl text-left mb-8 space-y-4 shadow-inner">
        {plan === 'individual' ? (
          <div>
            <h2 class="text-sm font-bold text-cyan-600 mb-2">⚠️ 次のステップ：受講日時のご予約</h2>
            <p class="text-slate-600 text-xs leading-relaxed mb-4">
              個別コースは事前予約制です。以下のボタンをクリックし、外部予約システム（Googleカレンダー）からご希望のレッスン日時を選択してください。
            </p>
            <a 
              href={bookingUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center w-full py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-cyan-600 font-bold text-white shadow-md shadow-indigo-600/15 hover:opacity-90 transition-opacity text-sm text-center"
            >
              🗓 レッスン日時を予約する (外部サイトへ)
            </a>
          </div>
        ) : (
          <div>
            <h2 class="text-sm font-bold text-indigo-600 mb-2">今後のスケジュール・ご案内</h2>
            <p class="text-slate-600 text-xs leading-relaxed">
              ご登録いただいたメールアドレス宛に、24時間以内に受講案内メールをお送りいたします。<br /><br />
              メール内に、講義用の **Google Meet 参加URL** や講義スケジュールを記載しておりますので、今しばらくお待ちください。
            </p>
          </div>
        )}
      </div>

      <div class="border-t border-slate-200 pt-6 space-y-4">
        <p class="text-slate-500 text-[11px] leading-relaxed">
          ※確認メールが届かない場合は、迷惑メールフォルダをご確認いただくか、事務局までご連絡ください。
        </p>
        <div class="flex justify-center gap-4">
          <a href={baseUrl} class="px-5 py-2.5 rounded-full bg-white border border-slate-200 text-slate-600 hover:text-slate-800 transition-colors text-xs font-bold shadow-sm">
            ホームへ戻る
          </a>
          <a href={`${baseUrl}articles`} class="px-5 py-2.5 rounded-full bg-white border border-slate-200 text-indigo-600 hover:text-indigo-500 transition-colors text-xs font-bold shadow-sm">
            お役立ち記事を読む
          </a>
        </div>
      </div>

    </div>
  </main>

  <!-- フッター -->
  <footer class="border-t border-slate-200 bg-white py-8 text-center text-slate-500 text-xs shadow-inner">
    <div class="max-w-6xl mx-auto px-4">
      <p>&copy; {new Date().getFullYear()} 生成AIStepSchool. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
